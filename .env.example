# Required
GEMINI_API_KEY=your-gemini-api-key
GITLAB_PAT=your-gitlab-personal-access-token

# GitLab target defaults (optional — can be set per incident in the UI)
GITLAB_TARGET_REPO=group/project
GITLAB_TARGET_BRANCH=main
GITLAB_BASE_URL=https://gitlab.com

# Application paths (optional — leave empty for repository root)
TARGET_APP_PATH=
APPLICATION_LOG_PATH=

# Platform settings
DATABASE_URL=sqlite:///./incidentops.db
INCIDENT_REGISTRY_PATH=incidents.json
DEFAULT_INCIDENT_ID=INC-101
DEMO_MODE=true
ENABLE_MODEL_FALLBACKS=false
